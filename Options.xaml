                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ToggleLabel" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SMTP: use STARTTLS / SSL" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="420" />
                    <Line Grid.Column="1" Stretch="Fill" X1="0" Y1="0" X2="1" Y2="0" Stroke="#666666" StrokeThickness="1" StrokeDashArray="1 3" VerticalAlignment="Center" Margin="6,0" />
                </Grid>
                <CheckBox Grid.Column="1" IsChecked="{Binding EmailUseSsl}" VerticalAlignment="Center" />
            </Grid>

            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <TextBlock Text="SMTP username" Margin="0,0,0,4" />
            <TextBox Text="{Binding EmailUsername, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource OptionsSettingField}" />
            <TextBlock Text="Usually your email address. Leave blank for open relay without auth." Margin="0,0,0,8" Opacity="0.7" TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left" />

            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <TextBlock Text="SMTP password" Margin="0,0,0,4" />
            <PasswordBox Loaded="EmailPassword_Loaded" PasswordChanged="EmailPassword_Changed"
                         Style="{StaticResource OptionsSettingPasswordField}" />
            <TextBlock Text="App password for Gmail/Outlook, or your SMTP password. Stored locally only." Margin="0,0,0,8" Opacity="0.7" TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left" />

            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <TextBlock Text="From address" Margin="0,0,0,4" />
            <TextBox Text="{Binding EmailFrom, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource OptionsSettingField}" />
            <TextBlock Text="Optional if SMTP username is your email. Proton Bridge requires your Proton address — custom domains like nina@home.local are rejected. Display name OK: NINA Graphs &lt;you@protonmail.com&gt;" Margin="0,0,0,8" Opacity="0.7" TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left" />

            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <TextBlock Text="To address(es)" Margin="0,0,0,4" />
            <TextBox Text="{Binding EmailTo, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource OptionsSettingField}" />
            <TextBlock Text="One or more recipients, separated by commas. Test email sends to yourself if this is blank." Margin="0,0,0,8" Opacity="0.7" TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left" />

            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <TextBlock Text="Email subject" Margin="0,0,0,4" />
            <TextBox Text="{Binding EmailSubjectTemplate, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource OptionsSettingField}" />
            <TextBlock Margin="0,0,0,8" Opacity="0.7" TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left">
                <Run Text="Leave blank for the default: " />
                <Run Text="NINA AutoFocus Graphs - {sequence} - {date}" FontFamily="Consolas" />
                <Run Text=" when a sequence is running, or " />
                <Run Text="NINA Manual AutoFocus Graphs - {date}" FontFamily="Consolas" />
                <Run Text=" for manual AF. Enter a custom subject only if you want something else — tokens: {sequence}, {date}, {time}, {filter}, {shortfilename}, {filename}, {reason}." />
            </TextBlock>

            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <Button Content="Test email" Click="TestEmail_Click" HorizontalAlignment="Left" Padding="12,4"
                        ToolTip="Send a short test email via SMTP." />
                <TextBlock Text="✓" FontSize="20" FontWeight="Bold" Foreground="#2ECC71" VerticalAlignment="Center" Margin="10,0,0,0"
                           Visibility="{Binding EmailTestSuccessVisible}" ToolTip="{Binding EmailTestToolTip}" />
                <TextBlock Text="✗" FontSize="20" FontWeight="Bold" Foreground="#E74C3C" VerticalAlignment="Center" Margin="10,0,0,0"
                           Visibility="{Binding EmailTestFailureVisible}" ToolTip="{Binding EmailTestToolTip}" />
            </StackPanel>
            <TextBlock Text="{Binding EmailTestStatusText}" Margin="0,0,0,12" Opacity="0.85" TextWrapping="Wrap" />
                    </StackPanel>
            </TabItem>
        </TabControl>
    </DataTemplate>
</ResourceDictionary>
