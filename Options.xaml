                <Button Content="Test webhook" Command="{Binding TestWebhookCommand}" HorizontalAlignment="Left" Padding="12,4"
                        ToolTip="Send a short test message to this Discord webhook to confirm the URL works." />
                <TextBlock Text="✓" FontSize="20" FontWeight="Bold" Foreground="#2ECC71" VerticalAlignment="Center" Margin="10,0,0,0"
                           Visibility="{Binding WebhookTestSuccessVisible}" ToolTip="Test message posted to Discord." />
                <TextBlock Text="✗" FontSize="20" FontWeight="Bold" Foreground="#E74C3C" VerticalAlignment="Center" Margin="10,0,0,0"
                           Visibility="{Binding WebhookTestFailureVisible}" ToolTip="{Binding WebhookTestToolTip}" />
            </StackPanel>

            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <TextBlock Text="Discord thread ID (optional)" Margin="0,0,0,4" />
            <TextBox Text="{Binding DiscordThreadId, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource OptionsSettingField}" />
            <TextBlock Text="Numeric thread ID for an existing thread. Leave empty to post in the channel." Margin="0,0,0,8" Opacity="0.7" TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left" />

            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <Grid Margin="0,0,0,10" ToolTip="Forum channels only. Posts go into a thread named AF yyyy-MM-dd for the night. Leave off for normal text channels (required — otherwise Discord returns an error).">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ToggleLabel" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Nightly forum thread name (AF yyyy-MM-dd)" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="420" />
                    <Line Grid.Column="1" Stretch="Fill" X1="0" Y1="0" X2="1" Y2="0" Stroke="#666666" StrokeThickness="1" StrokeDashArray="1 3" VerticalAlignment="Center" Margin="6,0" />
                </Grid>
                <CheckBox Grid.Column="1" IsChecked="{Binding UseNightlyThreadName}" VerticalAlignment="Center" />
            </Grid>
            <TextBlock Text="Forum channels only: posts go into a thread named AF yyyy-MM-dd for the night. Leave OFF for a normal text channel." Margin="0,0,0,8" Opacity="0.7" TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left" />

            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <TextBlock Text="Embed detail" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding EmbedModeOptions}" SelectedItem="{Binding EmbedMode}" Width="160" HorizontalAlignment="Left" Margin="0,0,0,8" />
            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <TextBlock Text="Attachments" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding AttachModeOptions}" SelectedItem="{Binding AttachMode}" Width="160" HorizontalAlignment="Left" Margin="0,0,0,12"
                      ToolTip="Both = graph + embed. GraphOnly = image with short message. EmbedOnly = text embed, no PNG." />

            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <TextBlock Text="Discord alert role ID (optional)" Margin="0,0,0,4" />
            <TextBox Text="{Binding DiscordAlertRoleId, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource OptionsSettingField}" />
            <TextBlock Text="Numeric role ID from Discord (Server Settings → Roles → right-click role → Copy Role ID). Used to ping on warnings or failures." Margin="0,0,0,8" Opacity="0.7" TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left" />

            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <Grid Margin="0,0,0,10" ToolTip="Mention the alert role (&lt;@&amp;roleId&gt;) in Discord when a quality warning is posted. Requires Discord alert role ID below.">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ToggleLabel" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Ping role on quality warning" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="420" />
                    <Line Grid.Column="1" Stretch="Fill" X1="0" Y1="0" X2="1" Y2="0" Stroke="#666666" StrokeThickness="1" StrokeDashArray="1 3" VerticalAlignment="Center" Margin="6,0" />
                </Grid>
                <CheckBox Grid.Column="1" IsChecked="{Binding PingRoleOnWarning}" VerticalAlignment="Center" />
            </Grid>
            <Grid Margin="0,0,0,10" ToolTip="Mention the alert role on failure posts and live autofocus aborts (no JSON report). Requires Discord alert role ID below.">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ToggleLabel" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Ping role on failure / live AF abort" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="420" />
                    <Line Grid.Column="1" Stretch="Fill" X1="0" Y1="0" X2="1" Y2="0" Stroke="#666666" StrokeThickness="1" StrokeDashArray="1 3" VerticalAlignment="Center" Margin="6,0" />
                </Grid>
                <CheckBox Grid.Column="1" IsChecked="{Binding PingRoleOnFailure}" VerticalAlignment="Center" />
            </Grid>
                    </StackPanel>
            </TabItem>
            <TabItem Header="Telegram">
                    <StackPanel Margin="0,4,0,0" Grid.IsSharedSizeScope="True">
<Grid Margin="0,0,0,10" ToolTip="Post autofocus graphs and digests to a Telegram chat or channel.">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ToggleLabel" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Enable Telegram" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="420" />
                    <Line Grid.Column="1" Stretch="Fill" X1="0" Y1="0" X2="1" Y2="0" Stroke="#666666" StrokeThickness="1" StrokeDashArray="1 3" VerticalAlignment="Center" Margin="6,0" />
                </Grid>
                <CheckBox Grid.Column="1" IsChecked="{Binding TelegramEnabled}" VerticalAlignment="Center" />
            </Grid>

            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <TextBlock Text="Telegram bot token" Margin="0,0,0,4" />
            <TextBox Text="{Binding TelegramBotToken, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource OptionsSettingField}" />
            <TextBlock Text="From @BotFather (e.g. 123456789:ABC...). Stored locally only." Margin="0,0,0,8" Opacity="0.7" TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left" />

            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <TextBlock Text="Telegram chat ID" Margin="0,0,0,4" />
            <TextBox Text="{Binding TelegramChatId, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource OptionsSettingField}" />
            <TextBlock Text="Numeric chat ID (e.g. -1001234567890) or @channelusername. Bot must be a member." Margin="0,0,0,8" Opacity="0.7" TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left" />

            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Test Telegram" Command="{Binding TestTelegramCommand}" HorizontalAlignment="Left" Padding="12,4"
                        ToolTip="Send a short test message via the Telegram Bot API." />
                <TextBlock Text="✓" FontSize="20" FontWeight="Bold" Foreground="#2ECC71" VerticalAlignment="Center" Margin="10,0,0,0"
                           Visibility="{Binding TelegramTestSuccessVisible}" ToolTip="Test message posted to Telegram." />
                <TextBlock Text="✗" FontSize="20" FontWeight="Bold" Foreground="#E74C3C" VerticalAlignment="Center" Margin="10,0,0,0"
                           Visibility="{Binding TelegramTestFailureVisible}" ToolTip="{Binding TelegramTestToolTip}" />
            </StackPanel>
                    </StackPanel>
            </TabItem>
            <TabItem Header="Slack">
                    <StackPanel Margin="0,4,0,0" Grid.IsSharedSizeScope="True">
<Grid Margin="0,0,0,10" ToolTip="Post autofocus graphs and digests to a Slack channel.">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="ToggleLabel" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Enable Slack" VerticalAlignment="Center" TextWrapping="Wrap" MaxWidth="420" />
                    <Line Grid.Column="1" Stretch="Fill" X1="0" Y1="0" X2="1" Y2="0" Stroke="#666666" StrokeThickness="1" StrokeDashArray="1 3" VerticalAlignment="Center" Margin="6,0" />
                </Grid>
                <CheckBox Grid.Column="1" IsChecked="{Binding SlackEnabled}" VerticalAlignment="Center" />
            </Grid>

            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <TextBlock Text="Slack bot token" Margin="0,0,0,4" />
            <TextBox Text="{Binding SlackBotToken, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource OptionsSettingField}" />
            <TextBlock Text="Bot User OAuth Token (xoxb-...) from your Slack app. Needs chat:write and files:write. Graph uploads use Slack's external upload API (Test Slack only sends text)." Margin="0,0,0,8" Opacity="0.7" TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left" />

            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <TextBlock Text="Slack channel ID" Margin="0,0,0,4" />
            <TextBox Text="{Binding SlackChannelId, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource OptionsSettingField}" />
            <TextBlock Text="Channel ID (C... or G...). Invite the bot to the channel before testing." Margin="0,0,0,8" Opacity="0.7" TextWrapping="Wrap" MaxWidth="640" HorizontalAlignment="Left" />

            <Rectangle Style="{StaticResource OptionsSettingSeparator}" />
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Test Slack" Command="{Binding TestSlackCommand}" HorizontalAlignment="Left" Padding="12,4"
